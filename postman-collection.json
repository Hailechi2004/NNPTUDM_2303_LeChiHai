{
  "info": {
    "name": "NNPTUD-S2 API Collection",
    "description": "API endpoints for user management and email testing",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"user01\",\n  \"password\": \"password123\"\n}"
            },
            "url": {
              "raw": "http://localhost:3000/auth/login",
              "protocol": "http",
              "host": ["localhost"],
              "port": "3000",
              "path": ["auth", "login"]
            }
          }
        },
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"newuser\",\n  \"password\": \"password123\",\n  \"email\": \"newuser@example.com\"\n}"
            },
            "url": {
              "raw": "http://localhost:3000/auth/register",
              "protocol": "http",
              "host": ["localhost"],
              "port": "3000",
              "path": ["auth", "register"]
            }
          }
        },
        {
          "name": "Forgot Password",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"user@example.com\"\n}"
            },
            "url": {
              "raw": "http://localhost:3000/auth/forgotpassword",
              "protocol": "http",
              "host": ["localhost"],
              "port": "3000",
              "path": ["auth", "forgotpassword"]
            }
          }
        },
        {
          "name": "Change Password",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Cookie",
                "value": "token=YOUR_TOKEN_HERE"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"oldPassword\": \"oldpass123\",\n  \"newPassword\": \"newpass123\"\n}"
            },
            "url": {
              "raw": "http://localhost:3000/auth/changepassword",
              "protocol": "http",
              "host": ["localhost"],
              "port": "3000",
              "path": ["auth", "changepassword"]
            }
          }
        }
      ]
    },
    {
      "name": "Upload",
      "item": [
        {
          "name": "Upload Excel Users",
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "formdata",
              "formdata": [
                {
                  "key": "file",
                  "type": "file",
                  "src": ""
                }
              ]
            },
            "url": {
              "raw": "http://localhost:3000/upload/excel/v2",
              "protocol": "http",
              "host": ["localhost"],
              "port": "3000",
              "path": ["upload", "excel", "v2"]
            }
          },
          "description": "Upload Excel file with columns: username, email. System will create users and send account creation emails."
        },
        {
          "name": "Upload Single Image",
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "formdata",
              "formdata": [
                {
                  "key": "file",
                  "type": "file",
                  "src": ""
                }
              ]
            },
            "url": {
              "raw": "http://localhost:3000/upload/single",
              "protocol": "http",
              "host": ["localhost"],
              "port": "3000",
              "path": ["upload", "single"]
            }
          }
        },
        {
          "name": "Upload Multiple Images",
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "formdata",
              "formdata": [
                {
                  "key": "files",
                  "type": "file",
                  "src": []
                }
              ]
            },
            "url": {
              "raw": "http://localhost:3000/upload/multiple",
              "protocol": "http",
              "host": ["localhost"],
              "port": "3000",
              "path": ["upload", "multiple"]
            }
          }
        }
      ]
    },
    {
      "name": "Users",
      "item": [
        {
          "name": "Create User",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Cookie",
                "value": "token=YOUR_ADMIN_TOKEN"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"newadmin\",\n  \"password\": \"adminpass123\",\n  \"email\": \"admin@example.com\",\n  \"role\": \"ROLE_ID_HERE\"\n}"
            },
            "url": {
              "raw": "http://localhost:3000/users",
              "protocol": "http",
              "host": ["localhost"],
              "port": "3000",
              "path": ["users"]
            }
          }
        },
        {
          "name": "Get All Users",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Cookie",
                "value": "token=YOUR_ADMIN_TOKEN"
              }
            ],
            "url": {
              "raw": "http://localhost:3000/users",
              "protocol": "http",
              "host": ["localhost"],
              "port": "3000",
              "path": ["users"]
            }
          }
        },
        {
          "name": "Get User by ID",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Cookie",
                "value": "token=YOUR_TOKEN"
              }
            ],
            "url": {
              "raw": "http://localhost:3000/users/USER_ID",
              "protocol": "http",
              "host": ["localhost"],
              "port": "3000",
              "path": ["users", "USER_ID"]
            }
          }
        }
      ]
    }
  ]
}
